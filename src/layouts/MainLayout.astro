---
import Base from "./BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Banner from "../components/Banner.astro";
import YukinaConfig from "../../yukina.config";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import MobileEnhancements from "../components/MobileEnhancements.astro";
import ImprovedMobileNav from "../components/ImprovedMobileNav.astro";

export interface Props {
  title?: string;
  subTitle?: string;
  bannerImage?: string;
  slug?: string;
  isHome?: boolean;
  headTitle?: string;
  headDescription?: string;
}

const {
  title,
  subTitle,
  bannerImage,
  slug,
  isHome = false,
  headTitle = title,
  headDescription = subTitle,
}: Props = Astro.props;
---

<Base title={headTitle} description={headDescription}>
  <meta name="page-type" content={isHome ? "home" : "content"} slot="head" />
  <slot name="head" slot="head" />

  <div id="page-container" class={isHome ? "is-home-page" : "is-content-page"} data-is-home={isHome.toString()}>
    <NavBar />

    {
      YukinaConfig.bannerStyle == "LOOP" && (
        <Banner title={title} subTitle={subTitle} bannerImage={bannerImage} slug={slug} />
      )
    }

    <div class="main-container">
      <div class="layout-grid">
        {!isHome && (
          <aside class="sidebar-container sticky-sidebar" id="main-sidebar">
            <SideBar />
          </aside>
        )}

        <div class="content-container">
          <main class="content transition-main">
            <slot />
          </main>
          <Footer />
        </div>
      </div>
    </div>
  </div>

  <MobileEnhancements />
  <ImprovedMobileNav />
</Base>

<style>
  .main-container {
    width: 100%;
    margin: 0 auto;
    padding: calc(4.8rem + var(--space-md)) var(--space-md) var(--space-2xl);
    max-width: calc(var(--page-width-xl) + var(--space-2xl));
  }

  .layout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .content-container {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .content {
    width: 100%;
    min-width: 0;
  }

  .sidebar-container {
    display: none;
    min-width: 16rem;
    max-width: 16rem;
  }

  .sticky-sidebar {
    position: sticky;
    top: calc(5rem + var(--space-xs));
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding-right: var(--space-xs);
  }

  .sticky-sidebar::-webkit-scrollbar {
    width: 0.28rem;
  }

  .sticky-sidebar::-webkit-scrollbar-thumb {
    background-color: var(--primary-color-lighten);
    border-radius: var(--radius-pill);
  }

  @media (min-width: 768px) {
    .main-container {
      padding-left: var(--space-lg);
      padding-right: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .main-container {
      max-width: calc(var(--page-width-lg) + var(--space-2xl));
      padding-top: calc(5.15rem + var(--space-md));
    }

    .is-content-page .layout-grid {
      grid-template-columns: minmax(0, 16rem) minmax(0, 1fr);
      gap: var(--space-xl);
    }

    .sidebar-container {
      display: block;
    }
  }

  @media (min-width: 1280px) {
    .main-container {
      max-width: calc(var(--page-width-xl) + var(--space-2xl));
    }
  }
</style>

<script>
  function applyPageStyles() {
    const container = document.getElementById("page-container");
    if (!container) {
      return;
    }

    const isHomePage = container.getAttribute("data-is-home") === "true";
    document.documentElement.dataset.layout = isHomePage ? "home" : "main";

    const sidebar = document.getElementById("main-sidebar");
    if (sidebar) {
      const shouldShow = !isHomePage && window.innerWidth >= 1024;
      sidebar.style.display = shouldShow ? "block" : "none";
    }
  }

  applyPageStyles();
  document.addEventListener("DOMContentLoaded", applyPageStyles);
  document.addEventListener("astro:after-swap", applyPageStyles);
  window.addEventListener("resize", applyPageStyles);
</script>
