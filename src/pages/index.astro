---
import MainLayout from "../layouts/MainLayout.astro";
import PostCard from "../components/PostCard.astro";
import MobilePostCard from "../components/MobilePostCard.astro";
import FeaturedPostsCarousel from "../components/FeaturedPostsCarousel.astro";
import TagCloud from "../components/widgets/TagCloud.astro";
import SearchBar from "../components/widgets/SearchBar.astro";
import Archive from "../components/Archive.astro";
import { GetSortedPosts, GetAllTags, GetAllCategories } from "../utils/content";
import { IdToSlug } from "../utils/hash";

const url = new URL(Astro.request.url);
const lang = (url.searchParams.get("lang") === "en" ? "en" : "ja") as "ja" | "en";
const langParam = lang === "en" ? "?lang=en" : "";

const allPosts = await GetSortedPosts(lang);
const allTags = await GetAllTags(lang);
const allCategories = await GetAllCategories(lang);

const MUST_READ_CANDIDATE_IDS = ["2025_10_19", "2025_10_12", "2025_09_28"];

const normalizePostId = (value: string) => IdToSlug(value.replace(/\.mdx?$/, ""));
const postsByNormalizedId = new Map(allPosts.map((post) => [normalizePostId(post.id), post]));

const curatedSeed = [] as typeof allPosts;
for (const candidateId of MUST_READ_CANDIDATE_IDS) {
  const found = postsByNormalizedId.get(normalizePostId(candidateId));
  if (found) {
    curatedSeed.push(found);
  }
}

const curatedSeedIds = new Set(curatedSeed.map((post) => normalizePostId(post.id)));
const curatedFallback = allPosts
  .filter((post) => !curatedSeedIds.has(normalizePostId(post.id)))
  .slice(0, Math.max(0, 3 - curatedSeed.length));

const mustReadPosts = [...curatedSeed, ...curatedFallback].slice(0, 3);
const mustReadIds = new Set(mustReadPosts.map((post) => normalizePostId(post.id)));

const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

const weeklyPriority = allPosts.filter(
  (post) => new Date(post.data.published) >= sevenDaysAgo && !mustReadIds.has(normalizePostId(post.id)),
);
const weeklyPriorityIds = new Set(weeklyPriority.map((post) => normalizePostId(post.id)));

const weeklyFallback = allPosts.filter(
  (post) => !mustReadIds.has(normalizePostId(post.id)) && !weeklyPriorityIds.has(normalizePostId(post.id)),
);

const weeklyPosts = [...weeklyPriority, ...weeklyFallback].slice(0, 6);

const topCategories = allCategories.slice(0, 6);
const categoryPicks: Array<{ category: any; post: any }> = topCategories
  .map((category) => {
    const representative = [...category.posts].sort(
      (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
    )[0];

    if (!representative) {
      return null;
    }

    return { category, post: representative };
  })
  .filter(Boolean) as Array<{ category: any; post: any }>;

const spotlightTags = allTags.slice(0, 24);

const heroTitle = lang === "ja" ? "意図から選べる読み口へ" : "Choose by reading intent";
const heroCopy =
  lang === "ja"
    ? "固定キュレーション、今週の更新、カテゴリ別ピックの3つの導線で、読みたい記事へ最短で辿れるトップに再構成しました。"
    : "The top page now offers three clear entry points: curated starters, weekly updates, and category picks.";

const weekWindowLabel = lang === "ja" ? "直近7日を優先表示" : "Prioritizing the last 7 days";
---

<MainLayout isHome={true}>
  <meta name="page-type" content="home" slot="head" />

  <div class="home-ia">
    <section class="hero-panel" aria-labelledby="home-hero-title">
      <p class="hero-eyebrow">Semiramisu Journal</p>
      <h1 id="home-hero-title" class="hero-title">{heroTitle}</h1>
      <p class="hero-copy">{heroCopy}</p>

      <div class="hero-stats" role="list" aria-label={lang === "ja" ? "サイト統計" : "Site stats"}>
        <div class="stat-card" role="listitem">
          <span class="stat-value">{allPosts.length}</span>
          <span class="stat-label">{lang === "ja" ? "公開記事" : "Published posts"}</span>
        </div>
        <div class="stat-card" role="listitem">
          <span class="stat-value">{allCategories.length}</span>
          <span class="stat-label">{lang === "ja" ? "カテゴリ" : "Categories"}</span>
        </div>
        <div class="stat-card" role="listitem">
          <span class="stat-value">{allTags.length}</span>
          <span class="stat-label">{lang === "ja" ? "タグ" : "Tags"}</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="#must-read" class="btn btn-primary">{lang === "ja" ? "まず読む3本" : "Start here"}</a>
        <a href="#weekly" class="btn btn-secondary">{lang === "ja" ? "今週の更新" : "Weekly updates"}</a>
        <a href="#category-picks" class="btn btn-ghost">{lang === "ja" ? "カテゴリ別ピック" : "Category picks"}</a>
      </div>
    </section>

    <section id="must-read" class="major-section" aria-labelledby="must-read-title">
      <div class="section-head">
        <h2 id="must-read-title" class="section-title">{lang === "ja" ? "まず読む3本" : "Start with these 3"}</h2>
        <p class="section-kicker">{lang === "ja" ? "固定候補ID + フォールバック" : "Fixed candidate IDs + fallback"}</p>
      </div>

      <FeaturedPostsCarousel posts={mustReadPosts} lang={lang} />

      <div class="next-read">
        <span class="next-read-label">{lang === "ja" ? "次に読む" : "Next reads"}</span>
        <div class="next-read-links">
          <a href={`/all-posts${langParam}`}>{lang === "ja" ? "最新一覧へ" : "Go to all posts"}</a>
          <a href={`/categories${langParam}`}>{lang === "ja" ? "カテゴリから探す" : "Browse categories"}</a>
          <a href={`/archive${langParam}`}>{lang === "ja" ? "時系列で遡る" : "Explore archive"}</a>
        </div>
      </div>
    </section>

    <section id="weekly" class="major-section" aria-labelledby="weekly-title">
      <div class="section-head">
        <h2 id="weekly-title" class="section-title">{lang === "ja" ? "今週の更新" : "This week’s updates"}</h2>
        <p class="section-kicker">{weekWindowLabel}</p>
      </div>

      <div class="posts-grid desktop-only">
        {weeklyPosts.map((entry, index) => (
          <div class="post-appear" style={`animation-delay: ${index * 0.07}s;`}>
            <PostCard
              id={entry.id}
              title={entry.data.title}
              published={entry.data.published}
              category={entry.data.category}
              tags={entry.data.tags}
              description={entry.data.description}
              image={entry.data.cover}
              readingMetadata={entry.readingMetadata}
              lang={lang}
            />
          </div>
        ))}
      </div>

      <div class="mobile-only mobile-posts">
        {weeklyPosts.map((entry, index) => (
          <MobilePostCard
            id={entry.id}
            title={entry.data.title}
            published={entry.data.published}
            category={entry.data.category}
            tags={entry.data.tags}
            description={entry.data.description}
            image={entry.data.cover}
            readingMetadata={entry.readingMetadata}
            lang={lang}
            isCompact={index > 0}
          />
        ))}
      </div>

      <div class="next-read">
        <span class="next-read-label">{lang === "ja" ? "次に読む" : "Next reads"}</span>
        <div class="next-read-links">
          <a href={`/all-posts${langParam}`}>{lang === "ja" ? "最新をさらに見る" : "More recent posts"}</a>
          <a href={`/tags${langParam}`}>{lang === "ja" ? "タグで広げる" : "Expand by tags"}</a>
          <a href={`/archive${langParam}`}>{lang === "ja" ? "週次から年次へ" : "From weekly to yearly"}</a>
        </div>
      </div>
    </section>

    <section id="category-picks" class="major-section" aria-labelledby="category-picks-title">
      <div class="section-head">
        <h2 id="category-picks-title" class="section-title">{lang === "ja" ? "カテゴリ別ピック" : "Category picks"}</h2>
        <p class="section-kicker">{lang === "ja" ? "カテゴリごとに代表1件" : "One representative post per category"}</p>
      </div>

      <div class="category-pick-grid desktop-only">
        {categoryPicks.map(({ category, post }, index) => (
          <article class="category-pick-item post-appear" style={`animation-delay: ${index * 0.08}s;`}>
            <div class="category-pick-head">
              <a href={`${category.slug}${langParam}`} class="category-pill">{category.name}</a>
              <a href={`${category.slug}${langParam}`} class="category-more">{lang === "ja" ? "カテゴリを見る" : "View category"}</a>
            </div>
            <PostCard
              id={post.id}
              title={post.title}
              published={post.date}
              category={category.name}
              tags={post.tags}
              description={post.description}
              image={post.cover}
              readingMetadata={post.readingMetadata}
              lang={lang}
            />
          </article>
        ))}
      </div>

      <div class="mobile-only mobile-posts">
        {categoryPicks.map(({ category, post }, index) => (
          <article class="mobile-category-item">
            <div class="mobile-category-head">
              <a href={`${category.slug}${langParam}`} class="category-pill">{category.name}</a>
            </div>
            <MobilePostCard
              id={post.id}
              title={post.title}
              published={post.date}
              category={category.name}
              tags={post.tags}
              description={post.description}
              image={post.cover}
              readingMetadata={post.readingMetadata}
              lang={lang}
              isCompact={index > 0}
            />
          </article>
        ))}
      </div>

      <div class="next-read">
        <span class="next-read-label">{lang === "ja" ? "次に読む" : "Next reads"}</span>
        <div class="next-read-links">
          <a href={`/categories${langParam}`}>{lang === "ja" ? "カテゴリ一覧へ" : "All categories"}</a>
          <a href={`/all-posts${langParam}`}>{lang === "ja" ? "最新一覧で横断" : "Cross-read all posts"}</a>
          <a href={`/archive${langParam}`}>{lang === "ja" ? "アーカイブへ" : "Go to archive"}</a>
        </div>
      </div>
    </section>

    <section id="discover" class="discover-grid" aria-label={lang === "ja" ? "検索とタグ" : "Search and tags"}>
      <article class="panel search-panel">
        <div class="section-head">
          <h2 class="section-title">{lang === "ja" ? "検索" : "Search"}</h2>
          <a href={`/search${langParam}`} class="section-link">{lang === "ja" ? "詳細検索" : "Advanced search"}</a>
        </div>
        <p class="section-copy">
          {lang === "ja"
            ? "キーワードで過去記事を横断検索し、関心に近い記録へすぐ移動できます。"
            : "Search across the full archive and jump directly to relevant notes."}
        </p>
        <SearchBar />
      </article>

      <article class="panel tag-panel">
        <div class="section-head">
          <h2 class="section-title">{lang === "ja" ? "タグ導線" : "Tag discovery"}</h2>
          <a href={`/tags${langParam}`} class="section-link">{lang === "ja" ? "タグ一覧" : "All tags"}</a>
        </div>
        <TagCloud tags={spotlightTags} maxTags={24} />
      </article>
    </section>

    <section id="archive" class="panel archive-panel" aria-labelledby="archive-title">
      <div class="section-head">
        <h2 id="archive-title" class="section-title">{lang === "ja" ? "アーカイブ" : "Archive"}</h2>
        <a href={`/archive${langParam}`} class="section-link">{lang === "ja" ? "年別アーカイブ" : "Yearly archive"}</a>
      </div>
      <Archive posts={allPosts} lang={lang} />
    </section>
  </div>
</MainLayout>

<style>
  .home-ia {
    --space-xs: 0.375rem;
    --space-sm: 0.625rem;
    --space-md: 1rem;
    --space-lg: 1.5rem;
    --space-xl: 2.25rem;
    --space-2xl: 3.5rem;
    --radius-card: 14px;
    --radius-pill: 9999px;
    --font-brand: var(--brand-font);
    --font-heading: var(--title-font);
    --font-body: var(--primary-font);
    --surface-1: color-mix(in oklch, var(--card-color) 84%, var(--primary-color-lighten));
    --surface-2: color-mix(in oklch, var(--background-color) 72%, var(--card-color));
    display: grid;
    gap: var(--space-2xl);
    padding: 0 var(--space-md);
    font-family: var(--font-body);
    color: var(--text-color);
  }

  .hero-panel {
    position: relative;
    border: 1px solid color-mix(in oklch, var(--token-accent) 20%, var(--border-color));
    border-radius: calc(var(--radius-card) + 6px);
    background: linear-gradient(
      145deg,
      color-mix(in oklch, var(--surface-1) 82%, var(--token-primary-lighten)),
      color-mix(in oklch, var(--surface-2) 78%, var(--token-accent-lighten))
    );
    padding: var(--space-xl);
    animation: rise-in 0.65s ease-out both;
    overflow: hidden;
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1.5px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--token-primary), var(--token-accent));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.3;
    pointer-events: none;
  }

  .hero-eyebrow {
    display: inline-flex;
    margin-bottom: var(--space-md);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-color);
    background: color-mix(in oklch, var(--card-color) 80%, var(--primary-color-lighten));
    padding: var(--space-xs) var(--space-lg);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-color-lighten);
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-brand);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.15;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-copy {
    margin-top: var(--space-lg);
    max-width: 70ch;
    font-size: clamp(1rem, 2vw, 1.12rem);
    line-height: 1.7;
    color: var(--text-color-lighten);
  }

  .hero-stats {
    margin-top: var(--space-xl);
    display: grid;
    gap: var(--space-md);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .stat-card {
    position: relative;
    border: 1px solid transparent;
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--card-color) 88%, var(--token-primary-lighten));
    padding: var(--space-md);
    display: grid;
    gap: 0.2rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: var(--gradient-border);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.4;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
  }

  .stat-card:hover::before {
    opacity: 0.8;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.6vw, 2rem);
    font-weight: 700;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-color-lighten);
  }

  .hero-actions {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--gradient-hero);
    color: white;
    font-weight: 600;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
  }

  .btn-secondary {
    background: color-mix(in oklch, var(--primary-color-lighten) 70%, var(--card-color));
    border-color: var(--border-color);
    color: var(--text-color);
  }

  .btn-ghost {
    background: transparent;
    border-color: var(--border-color);
    color: var(--text-color-lighten);
  }

  .major-section,
  .panel {
    border: 1px solid var(--border-color);
    border-radius: var(--radius-card);
    background: var(--surface-2);
    padding: var(--space-lg);
    animation: rise-in 0.6s ease-out both;
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .section-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2.5vw, 1.95rem);
    font-weight: 700;
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: var(--gradient-border);
  }

  .section-kicker {
    margin: 0;
    color: var(--text-color-lighten);
    font-size: 0.86rem;
  }

  .section-copy {
    margin: 0;
    color: var(--text-color-lighten);
    line-height: 1.7;
  }

  .section-link {
    color: var(--primary-color);
    font-family: var(--font-heading);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .post-appear {
    opacity: 0;
    animation: rise-in 0.45s ease-out forwards;
  }

  .category-pick-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  .category-pick-item {
    display: grid;
    gap: var(--space-sm);
  }

  .category-pick-head,
  .mobile-category-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--primary-color-lighten) 72%, var(--card-color));
    color: var(--primary-color-darken);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.18rem 0.65rem;
  }

  .category-more {
    color: var(--text-color-lighten);
    font-size: 0.78rem;
    text-decoration: none;
  }

  .next-read {
    margin-top: var(--space-lg);
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-md);
    display: grid;
    gap: var(--space-sm);
  }

  .next-read-label {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    color: var(--text-color-lighten);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .next-read-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .next-read-links a {
    border: 1px solid var(--border-color);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--card-color) 86%, var(--background-color));
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.84rem;
    padding: 0.3rem 0.75rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .next-read-links a:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  .discover-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1.15fr 0.85fr;
  }

  .tag-panel :global(.tag-cloud) {
    padding: var(--space-md);
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--card-color) 90%, var(--background-color));
  }

  .desktop-only {
    display: block;
  }

  .mobile-only {
    display: none;
  }

  .mobile-posts {
    display: none;
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1279px) {
    .posts-grid,
    .category-pick-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .discover-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .home-ia {
      gap: var(--space-xl);
      padding: 0;
    }

    .hero-panel,
    .major-section,
    .panel {
      padding: var(--space-md);
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .section-head {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: var(--space-md);
    }

    .desktop-only {
      display: none;
    }

    .mobile-only,
    .mobile-posts {
      display: block;
    }

    .next-read-links {
      flex-direction: column;
      align-items: stretch;
    }

    .next-read-links a {
      text-align: center;
    }
  }
</style>
