---
import { IdToSlug } from "../utils/hash";
import { Icon } from "astro-icon/components";
import { GetCoverURLForUnspecifiedEntry } from "../utils/cover";
import YukinaConfig from "../../yukina.config";
import { formatDate } from "../utils/date";
import ResponsiveImage from "./ResponsiveImage.astro";
import type { ReadingMetadata } from "../utils/reading-time";

export interface Props {
  id: string;
  title: string;
  published: Date;
  category?: string;
  tags?: string[];
  description?: string;
  image?: string;
  readingMetadata?: ReadingMetadata;
  lang?: "ja" | "en";
  isCompact?: boolean;
}

const props = Astro.props;
const baseUrl = props.id.startsWith("/") ? props.id : `/posts/${IdToSlug(props.id)}`;
const langParam = props.lang === "en" ? "?lang=en" : "";
const contentUrl = `${baseUrl}${langParam}`;
const entryID = props.id.startsWith("/") ? props.id.split("/").pop()! : IdToSlug(props.id);
const { time = 0 } = props.readingMetadata ?? { time: 0 };

const imageUrl = props.image ?? GetCoverURLForUnspecifiedEntry(entryID);
const isCompact = props.isCompact ?? false;
const minuteLabel = props.lang === "en" ? "min" : "分";
---

{isCompact ? (
  <article class="mobile-card compact">
    <a href={contentUrl} class="card-link">
      <div class="compact-image-wrap">
        <ResponsiveImage src={imageUrl} alt={props.title} width={140} height={104} loading="lazy" class="compact-image" />
      </div>
      <div class="compact-body">
        <h3 class="compact-title">{props.title}</h3>
        <p class="compact-description">{props.description}</p>
        <div class="compact-meta">
          <span>{formatDate(props.published, YukinaConfig.locale)}</span>
          {props.category && (
            <>
              <span class="meta-dot">•</span>
              <span>{props.category}</span>
            </>
          )}
          <span class="meta-dot">•</span>
          <span>
            {time}
            {minuteLabel}
          </span>
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="mobile-card featured">
    <a href={contentUrl} class="card-link full-link">
      <div class="featured-image-wrap">
        <ResponsiveImage src={imageUrl} alt={props.title} width={640} height={360} loading="lazy" class="featured-image" />
        <div class="featured-overlay">
          <span class="featured-category">{props.category || (props.lang === "en" ? "Post" : "記事")}</span>
          <span class="featured-reading-time">
            <Icon name="mingcute:time-line" width={15} height={15} />
            {time}
            {minuteLabel}
          </span>
        </div>
      </div>
      <div class="featured-body">
        <h2 class="featured-title">{props.title}</h2>
        <p class="featured-description">{props.description}</p>
        <div class="featured-footer">
          <span class="featured-date">{formatDate(props.published, YukinaConfig.locale)}</span>
          {props.tags && props.tags.length > 0 && (
            <div class="featured-tags">
              {props.tags.slice(0, 3).map((tag) => (
                <span class="tag-badge">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </a>
  </article>
)}

<style>
  .mobile-card {
    border: 1px solid var(--border-color);
    border-radius: 14px;
    overflow: hidden;
    background: color-mix(in oklch, var(--card-color) 88%, var(--background-color));
    margin-bottom: 0.9rem;
    transition: transform 0.2s var(--transition-timing),
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .mobile-card:active {
    transform: scale(0.97);
    border-color: var(--token-accent);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--token-accent) 16%, transparent);
  }

  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .compact .card-link {
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem;
  }

  .compact-image-wrap {
    flex-shrink: 0;
    width: 120px;
    height: 88px;
    border-radius: 11px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .compact-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .compact-body {
    min-width: 0;
    display: grid;
    gap: 0.35rem;
  }

  .compact-title {
    margin: 0;
    font-family: var(--title-font);
    font-size: 0.98rem;
    line-height: 1.4;
    color: var(--text-color);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .compact-description {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text-color-lighten);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .compact-meta {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.74rem;
    color: var(--text-color-lighten);
  }

  .meta-dot {
    opacity: 0.55;
  }

  .featured-image-wrap {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: linear-gradient(
      180deg,
      color-mix(in oklch, var(--text-color) 8%, transparent),
      color-mix(in oklch, var(--text-color) 42%, transparent)
    );
  }

  .featured-category {
    border-radius: 9999px;
    border: 1px solid color-mix(in oklch, var(--background-color) 20%, transparent);
    background: color-mix(in oklch, var(--primary-color) 60%, transparent);
    color: color-mix(in oklch, var(--background-color) 94%, var(--card-color));
    padding: 0.2rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .featured-reading-time {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    color: color-mix(in oklch, var(--background-color) 92%, var(--card-color));
    font-size: 0.78rem;
    font-weight: 600;
  }

  .featured-body {
    padding: 0.95rem;
    display: grid;
    gap: 0.6rem;
  }

  .featured-title {
    margin: 0;
    font-family: var(--title-font);
    font-size: 1.1rem;
    line-height: 1.35;
    color: var(--text-color);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-description {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-color-lighten);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .featured-date {
    font-size: 0.78rem;
    color: var(--text-color-lighten);
  }

  .featured-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag-badge {
    border-radius: 9999px;
    border: 1px solid var(--border-color);
    background: color-mix(in oklch, var(--primary-color-lighten) 72%, var(--card-color));
    color: var(--primary-color);
    padding: 0.14rem 0.5rem;
    font-size: 0.72rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .mobile-card {
      display: none;
    }
  }
</style>
