---
import YukinaConfig from "../../yukina.config";
import { GetCoverURLForUnspecifiedEntry } from "../utils/cover";
import ResponsiveImage from "./ResponsiveImage.astro";
import OptimizedImage from "./OptimizedImage.astro";

import banner1 from "../assets/banners/IMG_3258.jpg";
import banner2 from "../assets/banners/IMG_4018.jpg";
import banner3 from "../assets/banners/IMG_4033.JPG";
import banner4 from "../assets/banners/IMG_4035.JPG";
import banner5 from "../assets/banners/IMG_4345.jpg";

const bannerImages = [banner1, banner2, banner3, banner4, banner5];

export interface Props {
  title?: string;
  subTitle?: string;
  bannerImage?: string;
  slug?: string;
}

const { title, subTitle, bannerImage, slug } = Astro.props;

const hasTitle = title !== undefined || subTitle !== undefined;
const hasHeaderImg = bannerImage !== undefined || slug !== undefined;
const carouselAnimationTime = `${bannerImages.length * 6}s`;
---

<header id="banner" class="banner onload-animation-fade-in">
  <div class="banner-visual">
    {
      !hasHeaderImg && (
        <div class="carousel" data-banner-carousel>
          <ul id="carousel_imgs">
            {bannerImages.map((img, index) => (
              <li class="item" style={{ animationDelay: `${index * 6}s` }}>
                <OptimizedImage
                  src={img}
                  alt="Banner"
                  class="carousel-image"
                  width={1920}
                  height={720}
                  loading="eager"
                  format="webp"
                />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      hasHeaderImg && (
        <div class="cover">
          <ResponsiveImage
            class="cover-image"
            src={bannerImage ?? GetCoverURLForUnspecifiedEntry(slug ?? "")}
            alt="PostCover"
          />
        </div>
      )
    }
  </div>

  <div class="banner-overlay"></div>

  <div class="banner-content">
    <p class="banner-kicker">Semiramisu Journal</p>
    <h1 class:list={[hasTitle ? "title-normal" : "title-index"]} class="title">
      {title ?? YukinaConfig.title}
    </h1>
    <p class="subtitle">{subTitle ?? YukinaConfig.subTitle}</p>
  </div>

  <div class="waves" id="header-waves" aria-hidden="true">
    <svg
      class="waves-svg"
      xmlns="http://www.w3.org/2000/svg"
      xmlns:xlink="http://www.w3.org/1999/xlink"
      viewBox="0 24 150 28"
      preserveAspectRatio="none"
      shape-rendering="auto"
    >
      <defs>
        <path
          id="gentle-wave"
          d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"
        >
        </path>
      </defs>
      <g class="parallax">
        <use xlink:href="#gentle-wave" x="48" y="0" class="wave-1"></use>
        <use xlink:href="#gentle-wave" x="48" y="3" class="wave-2"></use>
        <use xlink:href="#gentle-wave" x="48" y="5" class="wave-3"></use>
        <use xlink:href="#gentle-wave" x="48" y="7" class="wave-4"></use>
      </g>
    </svg>
  </div>
</header>

<script>
  function initCarouselAnimation() {
    const carouselImgs = document.getElementById("carousel_imgs");
    const carouselImgsCount = carouselImgs?.children.length ?? 0;

    if (carouselImgsCount > 0) {
      const bannerElement = document.getElementById("banner");
      if (bannerElement && !bannerElement.querySelector("style[data-carousel]")) {
        const styleElement = document.createElement("style");
        styleElement.setAttribute("data-carousel", "");
        const carouselAnimation = `
        @keyframes carousel-animation {
          0% {
            opacity: 0;
            transform: scale(0.9);
          }
          4% {
            opacity: 1;
          }
          ${100 / carouselImgsCount}% {
            opacity: 1;
          }
          ${100 / carouselImgsCount + 50 / carouselImgsCount}% {
            opacity: 0;
          }
          100% {
            opacity: 0;
            transform: scale(1.08);
          }
        }
        `;
        styleElement.textContent = carouselAnimation;
        bannerElement.appendChild(styleElement);
      }
    }
  }

  // ViewTransitions対応: 初回ロードとページ遷移の両方で実行
  document.addEventListener("astro:page-load", initCarouselAnimation);
</script>

<style define:vars={{ carouselAnimationTime }}>
  .banner {
    position: relative;
    height: calc(var(--banner-height) * 0.78);
    min-height: 360px;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }

  .banner-visual,
  .carousel,
  .cover {
    position: absolute;
    inset: 0;
  }

  .carousel,
  .cover {
    background: color-mix(in oklch, var(--card-color) 88%, var(--background-color));
  }

  .carousel ul {
    margin: 0;
    padding: 0;
    list-style: none;
    width: 100%;
    height: 100%;
  }

  .carousel .item {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: carousel-animation var(--carouselAnimationTime) linear infinite;
    transform-origin: center;
  }

  .carousel-image,
  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 30%,
      color-mix(in oklch, var(--text-color) 46%, transparent) 100%
    );
    pointer-events: none;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    width: min(90vw, 980px);
    margin: 0 auto;
    height: calc(100% - 4.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    text-align: center;
    padding: 2rem 1rem 0;
  }

  .banner-kicker {
    width: fit-content;
    margin: 0 auto;
    border-radius: 9999px;
    border: 1px solid color-mix(in oklch, var(--background-color) 28%, transparent);
    background: color-mix(in oklch, var(--background-color) 12%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: color-mix(in oklch, var(--background-color) 94%, var(--card-color));
    padding: 0.28rem 0.88rem;
    font-family: var(--title-font);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .title {
    margin: 0;
    font-family: var(--brand-font);
    font-weight: 700;
    line-height: 1.15;
    color: color-mix(in oklch, var(--background-color) 94%, var(--card-color));
    text-wrap: balance;
    text-shadow: 0 4px 24px color-mix(in oklch, var(--token-primary-darken) 36%, transparent);
  }

  .title-index {
    font-size: clamp(2rem, 8vw, 4.7rem);
  }

  .title-normal {
    font-size: clamp(1.8rem, 5vw, 3.1rem);
  }

  .subtitle {
    margin: 0 auto;
    max-width: 72ch;
    color: color-mix(in oklch, var(--background-color) 82%, var(--card-color));
    font-family: var(--primary-font);
    font-size: clamp(0.96rem, 2vw, 1.24rem);
    line-height: 1.7;
    font-weight: 400;
  }

  .waves {
    position: absolute;
    inset: auto 0 -1px;
    height: 9vh;
    min-height: 3rem;
    max-height: 8rem;
    z-index: 2;
  }

  .waves-svg {
    width: 100%;
    height: 100%;
  }

  .parallax use {
    fill: var(--background-color);
    animation: wave 25s cubic-bezier(0.5, 0.5, 0.45, 0.5) infinite;
  }

  .wave-1 {
    opacity: 0.15;
    fill: var(--token-accent);
    animation-delay: -2s;
    animation-duration: 7s;
  }

  .wave-2 {
    opacity: 0.35;
    animation-delay: -3s;
    animation-duration: 10s;
  }

  .wave-3 {
    opacity: 0.6;
    animation-delay: -4s;
    animation-duration: 13s;
  }

  .wave-4 {
    opacity: 0.85;
    animation-delay: -5s;
    animation-duration: 20s;
  }

  @keyframes wave {
    0% {
      transform: translate3d(-90px, 0, 0);
    }
    100% {
      transform: translate3d(85px, 0, 0);
    }
  }

  @media (max-width: 767px) {
    .banner {
      min-height: 320px;
      height: calc(var(--banner-height) * 0.68);
    }

    .banner-content {
      height: calc(100% - 3.5rem);
      padding-top: 1.4rem;
    }
  }
</style>
