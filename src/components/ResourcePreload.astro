---
// 重要なリソースのプリロード設定
const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
---

<!-- Note: JS modulepreloads removed - Astro handles this automatically -->

<!-- 重要な画像のプリロード（ホームページのみ） -->
{isHomePage && (
  <>
    <!-- アバター画像 -->
    <link rel="preload" as="image" href="/icon.jpg" />
    
    <!-- Note: banner image preloads removed - hashes change per build -->
  </>
)}

<!-- リソースヒント -->
<link rel="dns-prefetch" href="https://fonts.bunny.net" />
<link rel="dns-prefetch" href="https://fastly.jsdelivr.net" />
<link rel="dns-prefetch" href="https://giscus.app" />
<link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
<link rel="preconnect" href="https://fastly.jsdelivr.net" crossorigin />

<!-- 重要なWeb Fontのプリロード -->
<!-- Note: font preloads removed - fonts are loaded async via BaseHead.astro -->

<script is:inline>
  // Resource Priority Hints API を使用
  if ('fetchpriority' in HTMLImageElement.prototype) {
    // 最初に表示される画像に高優先度を設定
    document.addEventListener('DOMContentLoaded', () => {
      const firstImages = document.querySelectorAll('.banner img, .hero-section img');
      firstImages.forEach((img, index) => {
        if (index < 3) {
          img.setAttribute('fetchpriority', 'high');
        }
      });
    });
  }
</script>