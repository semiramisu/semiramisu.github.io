---
import { Icon } from "astro-icon/components";
import { IdToSlug } from "../utils/hash";
import { GetCoverURLForUnspecifiedEntry } from "../utils/cover";
import { formatDate } from "../utils/date";
import YukinaConfig from "../../yukina.config";
import OptimizedImage from "./OptimizedImage.astro";

export interface Props {
  posts: any[];
  lang?: "ja" | "en";
}

const { posts, lang = "ja" } = Astro.props;
const langParam = lang === "en" ? "?lang=en" : "";
---

<div class="featured-carousel-container" data-featured-carousel>
  <div class="carousel-track-container">
    <div class="carousel-track">
      {posts.map((post) => {
        const entryID = IdToSlug(post.id);
        const contentUrl = `/posts/${entryID}${langParam}`;
        return (
          <article class="carousel-slide">
            <a href={contentUrl} class="slide-content">
              <OptimizedImage
                class="slide-image"
                src={post.data.cover ?? GetCoverURLForUnspecifiedEntry(entryID)}
                alt={post.data.title}
                width={960}
                height={520}
                loading="lazy"
              />
              <div class="slide-overlay">
                <span class="slide-category">{post.data.category ?? (lang === "ja" ? "記事" : "Post")}</span>
                <h3 class="slide-title">{post.data.title}</h3>
                {post.data.description && <p class="slide-description">{post.data.description}</p>}
                <div class="slide-meta">
                  <span class="meta-item">
                    <Icon name="cuida:calendar-outline" class="meta-icon" />
                    {formatDate(post.data.published, YukinaConfig.locale)}
                  </span>
                  <span class="meta-item read-more">
                    {lang === "ja" ? "続きを読む" : "Read more"}
                    <Icon name="cuida:caret-right-outline" class="meta-icon" />
                  </span>
                </div>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </div>

  <div class="controls" role="group" aria-label={lang === "ja" ? "スライド操作" : "Slide controls"}>
    <button class="control-button prev" aria-label={lang === "ja" ? "前へ" : "Previous"}>
      <Icon name="line-md:chevron-left" class="control-icon" />
    </button>
    <button class="control-button next" aria-label={lang === "ja" ? "次へ" : "Next"}>
      <Icon name="line-md:chevron-right" class="control-icon" />
    </button>
  </div>

  <div class="carousel-indicators">
    {posts.map((_, index) => (
      <button
        class={`indicator ${index === 0 ? "active" : ""}`}
        data-index={index}
        aria-label={`${lang === "ja" ? "スライド" : "Slide"} ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

<style>
  .featured-carousel-container {
    --radius-card: 14px;
    position: relative;
    width: 100%;
    height: clamp(320px, 48vw, 460px);
    overflow: hidden;
    border-radius: var(--radius-card);
    border: 1px solid var(--border-color);
    background: color-mix(in oklch, var(--card-color) 88%, var(--background-color));
  }

  .carousel-track-container {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.22, 0.68, 0, 1.02);
  }

  .carousel-slide {
    min-width: 100%;
    height: 100%;
  }

  .slide-content {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .slide-content:hover .slide-image {
    transform: scale(1.035);
  }

  .slide-overlay {
    position: absolute;
    inset: auto 0 0 0;
    display: grid;
    gap: 0.5rem;
    padding: 1.1rem;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in oklch, var(--token-primary-darken) 28%, transparent) 40%,
      color-mix(in oklch, var(--token-primary-darken) 62%, transparent) 100%
    );
    color: color-mix(in oklch, var(--background-color) 92%, var(--card-color));
  }

  .slide-category {
    width: fit-content;
    border-radius: 9999px;
    border: 1px solid color-mix(in oklch, var(--background-color) 24%, transparent);
    padding: 0.22rem 0.72rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: color-mix(in oklch, var(--primary-color) 58%, transparent);
    color: color-mix(in oklch, var(--background-color) 94%, var(--card-color));
  }

  .slide-title {
    margin: 0;
    font-family: var(--title-font);
    font-size: clamp(1.2rem, 2.6vw, 1.75rem);
    font-weight: 700;
    line-height: 1.3;
    color: color-mix(in oklch, var(--background-color) 92%, var(--card-color));
  }

  .slide-description {
    margin: 0;
    max-width: 64ch;
    line-height: 1.6;
    font-size: 0.95rem;
    color: color-mix(in oklch, var(--background-color) 82%, var(--card-color));
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .slide-meta {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.82rem;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: color-mix(in oklch, var(--background-color) 86%, var(--card-color));
  }

  .meta-icon {
    width: 1rem;
    height: 1rem;
  }

  .read-more {
    font-weight: 600;
  }

  .controls {
    position: absolute;
    inset: 50% 0 auto;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    justify-content: space-between;
    padding: 0 0.75rem;
    pointer-events: none;
  }

  .control-button {
    pointer-events: auto;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in oklch, var(--background-color) 24%, transparent);
    background: color-mix(in oklch, var(--card-color) 58%, transparent);
    color: color-mix(in oklch, var(--text-color) 90%, var(--background-color));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .control-button:hover {
    transform: translateY(-1px);
    border-color: var(--primary-color);
  }

  .control-icon {
    width: 1.3rem;
    height: 1.3rem;
  }

  .carousel-indicators {
    position: absolute;
    inset: auto 0 0.7rem;
    display: flex;
    justify-content: center;
    gap: 0.35rem;
    z-index: 2;
  }

  .indicator {
    width: 2.5rem;
    height: 3px;
    border: none;
    border-radius: 2px;
    background: color-mix(in oklch, var(--card-color) 40%, transparent);
    transition: background-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .indicator.active {
    background: color-mix(in oklch, var(--card-color) 30%, transparent);
  }

  .indicator.active::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--gradient-border);
    animation: indicator-fill 6.5s linear forwards;
  }

  @keyframes indicator-fill {
    from { transform: scaleX(0); transform-origin: left; }
    to { transform: scaleX(1); transform-origin: left; }
  }

  @media (max-width: 767px) {
    .featured-carousel-container {
      height: 350px;
    }

    .slide-overlay {
      padding: 0.95rem;
    }

    .slide-description {
      -webkit-line-clamp: 3;
      font-size: 0.9rem;
    }

    .controls {
      padding: 0 0.4rem;
    }
  }
</style>

<script>
  let activeCarouselCleanup: (() => void) | null = null;

  function cleanupCarousel() {
    if (activeCarouselCleanup) {
      activeCarouselCleanup();
      activeCarouselCleanup = null;
    }
  }

  function setupCarousel() {
    cleanupCarousel();

    const container = document.querySelector<HTMLElement>('[data-featured-carousel]');
    if (!container) return;

    const track = container.querySelector<HTMLElement>('.carousel-track');
    const slides = Array.from(container.querySelectorAll<HTMLElement>('.carousel-slide'));
    const prevButton = container.querySelector<HTMLButtonElement>('.control-button.prev');
    const nextButton = container.querySelector<HTMLButtonElement>('.control-button.next');
    const indicators = Array.from(container.querySelectorAll<HTMLButtonElement>('.indicator'));

    if (!track || slides.length === 0 || !prevButton || !nextButton) return;

    let currentIndex = 0;

    const render = (index: number) => {
      currentIndex = (index + slides.length) % slides.length;
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      indicators.forEach((indicator, indicatorIndex) => {
        indicator.classList.toggle('active', indicatorIndex === currentIndex);
      });
    };

    const handlePrev = () => render(currentIndex - 1);
    const handleNext = () => render(currentIndex + 1);

    prevButton.addEventListener('click', handlePrev);
    nextButton.addEventListener('click', handleNext);

    const indicatorHandlers = indicators.map((indicator, index) => {
      const handler = () => render(index);
      indicator.addEventListener('click', handler);
      return { indicator, handler };
    });

    const handleKeydown = (event: KeyboardEvent) => {
      if (event.key === 'ArrowLeft') handlePrev();
      if (event.key === 'ArrowRight') handleNext();
    };
    document.addEventListener('keydown', handleKeydown);

    let intervalId = window.setInterval(() => {
      render(currentIndex + 1);
    }, 6500);

    const stopAuto = () => {
      window.clearInterval(intervalId);
    };

    const restartAuto = () => {
      stopAuto();
      intervalId = window.setInterval(() => {
        render(currentIndex + 1);
      }, 6500);
    };

    container.addEventListener('mouseenter', stopAuto);
    container.addEventListener('mouseleave', restartAuto);

    render(0);

    activeCarouselCleanup = () => {
      prevButton.removeEventListener('click', handlePrev);
      nextButton.removeEventListener('click', handleNext);
      indicatorHandlers.forEach(({ indicator, handler }) => {
        indicator.removeEventListener('click', handler);
      });
      document.removeEventListener('keydown', handleKeydown);
      container.removeEventListener('mouseenter', stopAuto);
      container.removeEventListener('mouseleave', restartAuto);
      stopAuto();
    };
  }

  document.addEventListener('astro:page-load', setupCarousel);
  document.addEventListener('DOMContentLoaded', setupCarousel);

  if (document.readyState !== 'loading') {
    setTimeout(setupCarousel, 0);
  }
</script>
